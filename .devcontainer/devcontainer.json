{
  "name": "Matribhasha",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Matribhasha",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "bash -lc 'pgrep -f \"next dev\" >/dev/null || (npm run dev -- --hostname 0.0.0.0 > /tmp/matribhasha-next.log 2>&1 &)'"
}